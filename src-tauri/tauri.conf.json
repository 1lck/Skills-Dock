{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skills Dock",
  "version": "0.1.0",
  "identifier": "com.lick.skills-dock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "skills-dock",
        "width": 1480,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/1lck/Skills-Dock/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRCNUE3MDk0MDM1QzZCMTIKUldRU2Exd0RsSEJhUzNzajlXVkhjeFZybS9JSXlXTlhoakZkdWc2QjFmTmhpRDBpL1hmSE8zdHoK"
    }
  }
}
